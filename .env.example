# SERVER CONFIG
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# DATABASE CONFIG
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=timbangan

# VPS SSH REVERSE TUNNEL CONFIG
SSH_ENABLE=False
SSH_VPS_IP=YOUR_VPS_IP
SSH_USER=ubuntu
SSH_PASSWORD=YOUR_VPS_PASSWORD
SSH_REMOTE_PORT=8080

# RMI SCRAPER CONFIG
BASE_URL=https://apps.rejosomanisindo.com
RMI_USER=YOUR_RMI_USERNAME
RMI_PASS=YOUR_RMI_PASSWORD
MODULE_NAME=Crushing Monitor
TARGET_PATH=/crushingmonitor/MDC
